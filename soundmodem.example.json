{
  // pdn-soundmodem example configuration (JSON with comments allowed).
  // Start with: pdn-soundmodem --config soundmodem.json
  "device": "default",
  // A FlexRadio over the LAN is a device too: "flex:<radio>[:slice][@station]" — <radio> is
  // `discover`, an IP (host[:port]), a discovery spec (serial=…/name=…) or `mock`. With no
  // @station the daemon OWNS the radio and brings it up headless (creates its own slice — the
  // "flex" section below sets its frequency/antenna/mode). A trailing @station attaches to a
  // running SmartSDR's slice instead. The Flex keys itself, so omit "ptt". e.g.:
  //   "device": "flex:10.45.0.76",            // headless, slice A, 14.100000 MHz / ANT1 / DIGU
  //   "device": "flex:10.45.0.76:A@Flex",     // attach to SmartSDR station "Flex", slice A
  // "flex": { "frequency": "14.100000", "antenna": "ANT1", "mode": "DIGU" },
  "captureRate": 48000,
  "kissPort": 8105,
  "modems": [
    { "subChannel": 0, "mode": "afsk1200-multi", "frequency": 1700 },
    { "subChannel": 1, "mode": "bpsk300", "frequency": 1500 }
  ],
  "ptt": { "type": "cm108", "device": "/dev/hidraw0", "gpio": 3 },
  // POCSAG paging endpoint (optional; DAPNET/POCSAG-compatible waveform, local paging
  // API — line-based TCP: "PAGE <ric> <function> ALPHA|NUMERIC|TONE [text]").
  // "paging": { "port": 8106, "baud": 1200, "invertPolarity": false },
  // ARDOP virtual TNC (optional; ardopcf-compatible TCP host interface — Pat and
  // other Winlink hosts connect unmodified; data port is always port+1). The ARDOP
  // channel is dedicated: "ardop" is exclusive with "modems"/"paging", and the
  // channel must run at 12 kHz ("captureRate": 12000 recommended on aloop/bench).
  // "ardop": { "port": 8515 },
  "csma": {
    "txDelayMilliseconds": 300,
    "persistence": 63,
    "slotTimeMilliseconds": 100,
    "txTailMilliseconds": 20
  }
}
